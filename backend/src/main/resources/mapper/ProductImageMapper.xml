<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mingle_market.mapper.ProductImageMapper">
  <insert id="insertImage">
    INSERT INTO product_images (product_id, image_url)
    VALUES (#{productId}, #{imageUrl})
  </insert>

  <select id="getImagesByProductId" resultType="ProductImageDto">
    SELECT * FROM product_images
    WHERE product_id = #{productId}
    ORDER BY created_at ASC
  </select>

  <delete id="deleteImagesByProductId">
    DELETE FROM product_images WHERE product_id = #{productId}
  </delete>
</mapper>